{
  "name": "zod2md",
  "version": "0.3.2",
  "description": "Generate Markdown docs from Zod schemas",
  "license": "MIT",
  "author": "Matěj Chalk <matejchalk@gmail.com>",
  "keywords": [
    "markdown",
    "zod",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/matejchalk/zod2md.git"
  },
  "homepage": "https://github.com/matejchalk/zod2md#readme",
  "bugs": {
    "url": "https://github.com/matejchalk/zod2md/issues"
  },
  "type": "module",
  "files": [
    "dist/"
  ],
  "bin": "dist/bin.js",
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:update": "vitest run -u",
    "e2e": "vitest run --config e2e/vitest.config.ts",
    "e2e:update": "vitest run --config e2e/vitest.config.ts -u",
    "verdaccio:serve": "verdaccio --config .verdaccio/config.yml",
    "verdaccio:publish": "npm unpublish --registry http://localhost:4873 --force && npm publish --registry http://localhost:4873 --force",
    "release": "release-it",
    "release:dry-run": "release-it --dry-run"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12.0.0",
    "build-md": "^0.4.5",
    "bundle-require": "^5.1.0",
    "commander": "^12.0.0",
    "esbuild": "^0.25.4"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@code-pushup/eslint-config": "^0.15.1",
    "@eslint/js": "^9.39.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^22.16.0",
    "@vitest/eslint-plugin": "^1.6.9",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-sonarjs": "^1.0.4",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-cli-login": "^1.0.0",
    "prettier": "^3.8.1",
    "release-it": "^17.0.3",
    "tsup": "^8.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.0",
    "verdaccio": "^6.1.2",
    "vitest": "^3.2.4",
    "zod": "^4.0.5"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
